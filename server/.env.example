# Render backend environment variables
# Copy these into Render Dashboard > Your Web Service > Environment.

NODE_ENV=production
PORT=5000

# Frontend URL from Vercel. Replace with your deployed Vercel URL.
CLIENT_URL=https://YOUR_VERCEL_FRONTEND_URL.vercel.app

# MongoDB connection string.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/salon-management?retryWrites=true&w=majority

# JWT settings.
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRE=7d

# Admin creation/login secret used by admin routes.
ADMIN_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_ADMIN_SECRET

# Google OAuth web client ID. Must match VITE_GOOGLE_CLIENT_ID on the frontend.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_WEB_CLIENT_ID.apps.googleusercontent.com

# Firebase Admin SDK credentials for sending FCM from the backend.
# Paste the full service-account JSON as ONE LINE in Render.
# Keep this private; do not put it in Vercel/frontend variables.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"salon-management-554d6","private_key_id":"YOUR_PRIVATE_KEY_ID","private_key":"-----BEGIN PRIVATE KEY-----\\nYOUR_PRIVATE_KEY\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-fbsvc@salon-management-554d6.iam.gserviceaccount.com","client_id":"YOUR_CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-fbsvc%40salon-management-554d6.iam.gserviceaccount.com","universe_domain":"googleapis.com"}

# Email sending. For Gmail, use an app password, not your normal password.
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password

# Cloudinary media uploads.
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# Stripe payments.
STRIPE_SECRET_KEY=sk_live_OR_TEST_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Groq AI assistant.
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY
GROQ_STREAM_MODEL=llama-3.1-8b-instant
